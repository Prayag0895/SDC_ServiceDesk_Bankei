DB_NAME=sdc
DB_USER=postgres
DB_PASSWORD=change-this-db-password
DB_HOST=db
DB_PORT=5432

SECRET_KEY=change-this-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,SERVER_IP
CORS_ALLOWED_ORIGINS=http://SERVER_IP,http://localhost:4200,http://127.0.0.1:4200

# Optional: backend container bootstrap admin defaults (can also be set in docker-compose.prod.yml)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123
ADMIN_EMAIL=admin@sdc.local
ADMIN_ROLE=OFFICER
SEED_MASTER_DATA=true
SEED_DEMO_USERS=false
